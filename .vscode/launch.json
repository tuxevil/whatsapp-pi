{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug with Pi",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "pi",
            "runtimeArgs": [
                "-e",
                "${workspaceFolder}\\whatsapp-pi.ts"
            ],
            "console": "integratedTerminal",
            "outputCapture": "std"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug with Pi (continue)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "pi",
            "runtimeArgs": [
                "-e",
                "${workspaceFolder}\\whatsapp-pi.ts",
                "-c"
            ],
            "console": "integratedTerminal",
            "outputCapture": "std"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug with Pi (Verbose)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "pi",
            "runtimeArgs": [
                "-e",
                "${workspaceFolder}\\whatsapp-pi.ts",
                "--verbose"
            ],
            "console": "integratedTerminal",
            "outputCapture": "std"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug with Pi (Online)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "pi",
            "runtimeArgs": [
                "-e",
                "${workspaceFolder}\\whatsapp-pi.ts",
                "--whatsapp-pi-online"
            ],
            "console": "integratedTerminal",
            "outputCapture": "std"
        }
    ]
}